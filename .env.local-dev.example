# Tether local development preset
# Use this for one-machine or LAN testing.

# Shared auth
ORCHESTRATOR_API_KEY=dev-change-me

# Orchestrator
PORT=8000
ENABLE_NGROK=false
NGROK_AUTH_TOKEN=
TASK_LEASE_SECONDS=180
WORKER_STALE_SECONDS=45
MAX_TASK_ATTEMPTS=3
STATE_DB_PATH=./orchestrator_state.db
LOG_LEVEL=INFO
FFMPEG_PATH=ffmpeg
ENABLE_STITCHER=true
STITCHER_FPS=24

# Optional object storage (leave blank for local disk)
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=
S3_PRESIGN_EXPIRY=3600

# Worker / CLI
ORCHESTRATOR_URL=http://127.0.0.1:8000
WORKER_ID=
BLENDER_IMAGE=linuxserver/blender:latest
LOCAL_DIR=./node_data
POLL_INTERVAL_SECONDS=5
HEARTBEAT_INTERVAL_SECONDS=10
DRY_RUN=false
CPU_CLAIM_THRESHOLD=60.0
GPU_CLAIM_THRESHOLD=65.0
CPU_PAUSE_THRESHOLD=80.0
GPU_PAUSE_THRESHOLD=80.0
HEADROOM_CHECK_INTERVAL=3
