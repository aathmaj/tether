# Shared
ORCHESTRATOR_API_KEY=change-me

# Orchestrator
PORT=8000
ENABLE_NGROK=false
NGROK_AUTH_TOKEN=
TASK_LEASE_SECONDS=180
WORKER_STALE_SECONDS=45
MAX_TASK_ATTEMPTS=3
STATE_DB_PATH=./orchestrator_state.db
LOG_LEVEL=INFO

# Node Agent
ORCHESTRATOR_URL=http://127.0.0.1:8000
WORKER_ID=
BLENDER_IMAGE=linuxserver/blender:latest
LOCAL_DIR=./node_data
POLL_INTERVAL_SECONDS=5
HEARTBEAT_INTERVAL_SECONDS=10
DRY_RUN=false
