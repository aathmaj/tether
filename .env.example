# Shared
ORCHESTRATOR_API_KEY=change-me

# Orchestrator
PORT=8000
ENABLE_NGROK=false
NGROK_AUTH_TOKEN=
TASK_LEASE_SECONDS=180
WORKER_STALE_SECONDS=45
MAX_TASK_ATTEMPTS=3
STATE_DB_PATH=./orchestrator_state.db
LOG_LEVEL=INFO
FFMPEG_PATH=ffmpeg
ENABLE_STITCHER=true
STITCHER_FPS=24
UPLOAD_TOKEN_TTL_SECONDS=86400

# Optional object storage (S3 / Cloudflare R2)
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=
S3_PRESIGN_EXPIRY=3600

# Node Agent
ORCHESTRATOR_URL=http://127.0.0.1:8000
WORKER_ID=
BLENDER_IMAGE=linuxserver/blender:latest
APPROVED_EXECUTOR_IMAGES=linuxserver/blender:latest,python:3.11-slim,python:3.11-alpine,ubuntu:24.04,alpine:3.20,jrottenberg/ffmpeg:6.1,pytorch/pytorch:2.5.1-cuda12.1-cudnn9-runtime,tensorflow/tensorflow:2.16.1-gpu
LOCAL_DIR=./node_data
POLL_INTERVAL_SECONDS=5
HEARTBEAT_INTERVAL_SECONDS=10
DRY_RUN=false
DRY_RUN_GPU_VRAM_MB=16384
CPU_CLAIM_THRESHOLD=60.0
GPU_CLAIM_THRESHOLD=65.0
CPU_PAUSE_THRESHOLD=80.0
GPU_PAUSE_THRESHOLD=80.0
HEADROOM_CHECK_INTERVAL=3

# Executor image defaults used by the orchestrator when clients omit an explicit image
FFMPEG_EXECUTOR_IMAGE=jrottenberg/ffmpeg:6.1
PYTHON_EXECUTOR_IMAGE=python:3.11-slim
SHELL_EXECUTOR_IMAGE=alpine:3.20
MODEL_CACHE_DIR=./model_cache
DEFAULT_STABLE_DIFFUSION_IMAGE=ghcr.io/huggingface/text-generation-inference:latest
DEFAULT_LLM_IMAGE=pytorch/pytorch:2.5.1-cuda12.1-cudnn9-runtime
DEFAULT_WHISPER_IMAGE=ghcr.io/openai/whisper:latest
USE_LOCAL_EXECUTORS=false
MOCK_EXECUTORS_DIR=./workers/mock_executors

# CLI uses ORCHESTRATOR_URL and ORCHESTRATOR_API_KEY
