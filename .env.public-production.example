# Tether public production preset
# Use this for internet-facing deployments.
# Replace all placeholders before launch.

# Shared auth (required)
ORCHESTRATOR_API_KEY=replace-with-long-random-secret

# Orchestrator
PORT=8000
ENABLE_NGROK=false
NGROK_AUTH_TOKEN=
TASK_LEASE_SECONDS=300
WORKER_STALE_SECONDS=60
MAX_TASK_ATTEMPTS=4
STATE_DB_PATH=./orchestrator_state.db
LOG_LEVEL=INFO
FFMPEG_PATH=ffmpeg
ENABLE_STITCHER=true
STITCHER_FPS=24
UPLOAD_TOKEN_TTL_SECONDS=86400

# Object storage (recommended for production)
S3_ENDPOINT_URL=https://your-account-id.r2.cloudflarestorage.com
S3_ACCESS_KEY_ID=replace-me
S3_SECRET_ACCESS_KEY=replace-me
S3_BUCKET_NAME=tether-prod
S3_PRESIGN_EXPIRY=3600

# Worker / CLI
ORCHESTRATOR_URL=https://orchestrator.yourdomain.com
WORKER_ID=
BLENDER_IMAGE=linuxserver/blender:latest
LOCAL_DIR=./node_data
POLL_INTERVAL_SECONDS=5
HEARTBEAT_INTERVAL_SECONDS=10
DRY_RUN=false
CPU_CLAIM_THRESHOLD=55.0
GPU_CLAIM_THRESHOLD=60.0
CPU_PAUSE_THRESHOLD=85.0
GPU_PAUSE_THRESHOLD=85.0
HEADROOM_CHECK_INTERVAL=3
